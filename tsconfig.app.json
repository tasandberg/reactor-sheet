{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "types": ["fvtt-types"],

    /* Bundler mode */
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": false,
    "paths": {
      "@src/*": ["./src/*"],
      "@app": ["./src/ReactorSheet/app"],
      "@app/*": ["./src/ReactorSheet/app/*"],
      "@layout": ["./src/ReactorSheet/layout"],
      "@layout/*": ["./src/ReactorSheet/layout/*"],
      "@features": ["./src/ReactorSheet/features"],
      "@features/*": ["./src/ReactorSheet/features/*"],
      "@domain": ["./src/ReactorSheet/domain"],
      "@domain/*": ["./src/ReactorSheet/domain/*"],
      "@ui": ["./src/ReactorSheet/components/ui"],
      "@ui/*": ["./src/ReactorSheet/components/ui/*"]
    }
  }
}
